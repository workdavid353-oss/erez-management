# Copy this file to .env.docker and fill in the values.
# Replace SERVER_IP with the LAN IP of the server machine (e.g. 192.168.1.100)
# Workers' browsers connect to this IP — do NOT use localhost here.

VITE_SUPABASE_URL=http://SERVER_IP:8000
VITE_SUPABASE_ANON_KEY=paste_anon_key_from_env.local
VITE_SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_from_env.local
